{
  "name": "InfoCliente-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "build:css:base": "tailwindcss -i ./src/assets/styles/tailwind.input.css -o ./src/assets/styles/tailwind-base.css -c ./tailwind.base.config.cjs --minify",
    "build:css:app": "tailwindcss -i ./src/assets/styles/tailwind.input.css -o ./src/assets/styles/tailwind-app.css -c ./tailwind.app.config.cjs --minify",
    "build:css:clientes": "tailwindcss -i ./src/assets/styles/tailwind.input.css -o ./src/assets/styles/tailwind-clientes.css -c ./tailwind.clientes.config.cjs --minify",
    "build:css": "npm run build:css:base && npm run build:css:app && npm run build:css:clientes",
    "build": "npm run build:css && node build.js",
    "start": "node server.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^3.4.17"
  }
}
